#include <format>
#include <iostream>
#include <string>
#include <vector>

using std::cout;
using std::string;
using std::vector;

struct Row { 
    int id; 
    string name; 
    float income;
};

std::ostream& operator<<(std::ostream& os, const Row& r){
	os << r.id << ", " << r.name << ", " << r.income << '\n';
	return os;
}

template <typename RowSchema> 
vector<RowSchema> createDefaultTableEntries(int n){
    vector<RowSchema> ans(n); 
    return ans; 
}

int main(){
    // Note that we need to specify the type of RowSchema here
    vector<Row> tableRowStore = createDefaultTableEntries<Row>(10); 
    for(const auto& row : tableRowStore) cout << row;
    return 0;
}
